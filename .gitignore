# Python & system
__pycache__/
*.pyc
*.pyo
*.pyd
*.DS_Store
.venv/
.pytest_cache/

# IDE
.vscode/
.idea/

# Local configs & secrets
.env
.env.*
config/alpaca_keys.json

# Local working snapshots of config files (before-risky-change backups
# made on individual machines — not project history)
config/*.backup
config/*.backup-*
config/*-backup
config/*.pre-*
config/*.bak

# Logs and runtime data
data/
logs/
evolution.log
storage/*.json
storage/*.csv

# Aider
.aider*

# Claude Code personal/runtime state (keep door open for team-wide
# .claude/settings.json, .claude/agents/, .claude/commands/ if desired)
.claude/settings.local.json
.claude/*.lock
.claude/plans/

# Archived info
Archive/
# Agent worktree isolation directories (created by Agent tool isolation:worktree)
.claude/worktrees/
